# GodsEye SURVEILLANCE OPERATIONS CENTER - ENVIRONMENTAL VARIABLES
# Copy this file to '.env' and modify settings for production scopes.

# OpenAI Integration (Required for Natural Language Security Assistant & Automated Summaries)
# Leave blank to fall back automatically to the high-fidelity rule-based tactical engine.
OPENAI_API_KEY=your_openai_api_key_here

# JWT Security Configurations
# Secret signature used to hash security session tokens. Generate a secure random hex in prod.
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7

# Database Integrations
# Defaults to local serverless SQLite. Override with postgresql configurations if needed:
# Example: postgresql://user:password@localhost:5432/godseye
# DATABASE_URL=sqlite:///workspace/database/godseye_prod.db
